# ----- Docker Compose env file -----
# Copy to `.env` next to docker-compose.yml and edit values for your server.

# Database (default points at the in-compose mongo service)
MONGODB_URI=mongodb://mongo:27017/restaurant-memo
MONGO_DB=restaurant-memo

# App URL (used by webhooks/server-to-server fetches)
NEXTAUTH_URL=http://your-domain-or-ip
NEXTAUTH_SECRET=replace-with-a-long-random-string
JWT_SECRET=replace-with-a-long-random-string

# Paymob (optional — leave blank if not using card payments)
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_HMAC_SECRET=
PAYMOB_WEBHOOK_URL=
PAYMOB_CALLBACK_URL=
