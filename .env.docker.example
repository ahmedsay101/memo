# ----- Docker Compose env file -----
# Copy to `.env` next to docker-compose.yml and edit values for your server.

# Database (default points at the in-compose mongo service)
MONGODB_URI=mongodb://mongo:27017/restaurant-memo
MONGO_DB=restaurant-memo

# App URL (used by payment callbacks and server-to-server fetches)
NEXTAUTH_URL=https://memos-pizza.com
NEXTAUTH_SECRET=replace-with-a-long-random-string
JWT_SECRET=replace-with-a-long-random-string

# QNB MPGS (Visa / Mastercard card payments) — live gateway
MPGS_HOST_URL=qnbalahli.gateway.mastercard.com
MPGS_MERCHANT_ID=MEMOSPIZZA
MPGS_API_USERNAME=merchant.MEMOSPIZZA
MPGS_API_PASSWORD=your-mpgs-api-password
MPGS_API_VERSION=61
MPGS_CURRENCY=EGP
MPGS_CALLBACK_URL=https://memos-pizza.com/payment-callback
